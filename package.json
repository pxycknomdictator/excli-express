{
    "name": "@excli/express",
    "version": "2.9.1",
    "main": "dist/index.mjs",
    "type": "module",
    "types": "dist/index.d.mts",
    "description": "A cli tool for creating Express.js applications, supporting both JavaScript and TypeScript.",
    "scripts": {
        "build": "tsdown",
        "lint": "eslint src/**/*.ts",
        "start": "node dist/index.mjs",
        "lint:fix": "eslint src/**/*.ts --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
        "prepublishOnly": "npm run build",
        "prepare": "husky"
    },
    "keywords": [
        "@excli/express",
        "express",
        "express-generator",
        "express cli",
        "express generator",
        "express setup",
        "express typescript",
        "express boilerplate",
        "express starter",
        "nodejs boilerplate",
        "express docker",
        "express generator alternative",
        "modern express generator",
        "typescript express",
        "express scaffold",
        "backend generator",
        "production ready express",
        "nodejs express cli"
    ],
    "bin": {
        "excli": "./dist/index.mjs"
    },
    "author": "Noman <pxycknomdictator@gmail.com>",
    "license": "ISC",
    "files": [
        "dist/",
        "templates/",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=18.0.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/pxycknomdictator/excli-express.git"
    },
    "bugs": {
        "url": "https://github.com/pxycknomdictator/excli-express/issues"
    },
    "dependencies": {
        "@clack/prompts": "^0.11.0",
        "figlet": "^1.8.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.29.0",
        "@types/figlet": "^1.7.0",
        "@types/node": "^24.0.1",
        "eslint": "^9.29.0",
        "globals": "^16.2.0",
        "husky": "^9.1.7",
        "prettier": "^3.5.3",
        "tsdown": "^0.21.4",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.34.1"
    }
}
